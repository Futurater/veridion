# ==========================================
# Veridian WorkOS — Environment Variables
# Copy this file to .env and fill in values
# ==========================================

# Nvidia NIM (LLM + Embeddings)
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Jira (Live API)
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=VER

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# GitHub Webhooks
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# BambooHR Mock Server (Layer 1 complete — uses Supabase directly)
BAMBOOHR_BASE_URL=http://localhost:8001

# Google Sheets (Finance connector)
GOOGLE_SHEETS_CREDENTIALS_FILE=service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# App
APP_SECRET_KEY=your_random_secret_key_here
FRONTEND_URL=http://localhost:3000
